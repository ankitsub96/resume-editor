  align-items: center;
  padding-right: 18px;
  margin-right: 4px;
  border-right: 1px solid rgba(0,0,0,0.15);
}

.toolbar-left {
  display: flex;
  align-items: stretch;
}

.toolbar-center {
  display: flex;
  align-items: stretch;
  flex: 1;
  justify-content: center;
}

.toolbar-right {
  display: flex;
  align-items: stretch;
  gap: 2px;
  margin-left: auto;
}

.toolbar-sep {
  width: 1px;
  background: rgba(0,0,0,0.15);
