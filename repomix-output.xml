  padding: 3px 0 5px;
}

.section-items {
  display: flex;
  flex-direction: column;
  gap: var(--item-gap);
}

/* Item card */
.section-item {
  position: relative;
  container-type: inline-size;
  border-radius: 3px;
  transition: outline 0s;
}

.section-item:hover {
  outline: 1px solid color-mix(in srgb, var(--primary, #888) 40%, transparent);
}

.section-item:hover .item-remove-btn {
  opacity: 1;
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 8px;
  margin-bottom: 3px;
}

.item-header-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 1px;
}

.item-header-right {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-shrink: 0;
}

@container (max-width: 200px) {
  .item-header {
    display: grid;
    grid-template-columns: auto 1fr auto;
    grid-template-areas:
      "handle left   remove"
      ".      right  .";
    gap: 2px 6px;
  }
  .item-drag-handle {
    grid-area: handle;
    align-self: center;
  }
  .item-header-left {
    grid-area: left;
  }
  .item-remove-btn {
    grid-area: remove;
    align-self: flex-start;
  }
  .item-header-right {
    grid-area: right;
    justify-content: flex-start;
  }
  .item-header-right > div {
    align-items: flex-start !important;
  }
}

.item-title {
  font-size: 0.82em;
  font-weight: 700;
  color: var(--resume-text, #1a1a1a);
  display: block;
}

.item-subtitle {
  font-size: 0.75em;
  font-weight: 700;
  color: var(--primary-dark);
  font-style: italic;
  display: block;
}

.item-period {
  font-size: 0.72em;
  color: var(--resume-text, #1a1a1a);
  white-space: nowrap;
}

.item-location {
  font-size: 0.72em;
  color: var(--resume-text, #1a1a1a);
}

.item-remove-btn {
  opacity: 0;
  transition: opacity 0.15s;
  font-size: 1em;
  line-height: 1;
  color: #cc3333;
  padding: 0 2px;
  background: none;
  border: none;
  cursor: pointer;
  border-radius: 2px;
}

.item-remove-btn:hover {
  background: #fee;
}

/* Drag handles */
.item-drag-handle {
  font-size: 0.85em;
  color: #bbb;
  cursor: grab;
  padding: 0 4px 0 0;
  user-select: none;
  flex-shrink: 0;
  line-height: 1;
  opacity: 0.5;
  transition: opacity 0.15s, color 0.15s;
}
.item-drag-handle:active {
  cursor: grabbing;
}
.section-item:hover .item-drag-handle {
  opacity: 1;
  color: #444;
}

.bullet-drag {
  font-size: 0.75em;
  color: #aaa;
  cursor: grab;
  user-select: none;
  flex-shrink: 0;
  line-height: 1;
  opacity: 0.5;
  transition: opacity 0.15s, color 0.15s;
}
.bullet-drag:active {
  cursor: grabbing;
}
.bullet-item:hover .bullet-drag {
  opacity: 1;
  color: #444;
}

/* Bullet lists */
.bullet-list {
  list-style: none;
  padding: 0;
  margin: 2px 0 0;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.bullet-item {
  display: flex;
  align-items: flex-start;
  gap: 6px;
  font-size: 0.76em;
  line-height: var(--line-height);
  color: var(--resume-text, #333);
}

.bullet-item::before {
  content: "•";
  color: var(--primary);
  font-size: 0.9em;
  margin-top: 1px;
  flex-shrink: 0;
  order: 1;
}

.bullet-drag {
  order: 0;
}
.bullet-item > span:last-child {
  order: 2;
}

.bullet-add {
  font-size: 0.68em;
  color: #aaa;
  cursor: pointer;
  padding: 1px 0 1px 14px;
  user-select: none;
  list-style: none;
}

.bullet-add:hover {
  color: var(--primary);
}

/* Add item button */
.add-item-btn {
  margin-top: 6px;
  font-size: 0.72em;
  color: var(--primary);
  background: none;
  border: 1px dashed var(--primary);
  border-radius: 3px;
  padding: 3px 10px;
  cursor: pointer;
  opacity: 0.7;
  transition: opacity 0.15s;
}

.add-item-btn:hover {
  opacity: 1;
}

/* Sidebar (left column) section styling */
.column-left .item-title {
  font-size: 0.78em;
}

.column-left .bullet-item {
  font-size: 0.72em;
}
