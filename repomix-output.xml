/* Horizontally scrollable accent palette */
.accent-scroll {
  display: grid;
  grid-template-rows: repeat(3, auto);
  grid-auto-flow: column;
  grid-auto-columns: max-content;
  gap: 6px;
  overflow-x: auto;
  padding: 8px 4px 10px;
  scrollbar-width: thin;
  scrollbar-color: #ddd transparent;
  margin-bottom: 8px;
}

.accent-dot {
  width: 22px;
  height: 22px;
  border-radius: 50%;
  border: 1.5px solid rgba(0,0,0,0.12);
  cursor: pointer;
  flex-shrink: 0;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.12s, border-color 0.12s;
}
.accent-dot:hover { transform: scale(1.2); border-color: rgba(0,0,0,0.35); }
.accent-dot.active { border: 2.5px solid #fff; box-shadow: 0 0 0 2px rgba(0,0,0,0.5); }
.accent-dot .swatch-check { font-size: 0.6rem; color: #fff; font-weight: 700; text-shadow: 0 1px 2px rgba(0,0,0,0.5); }

/* Custom color picker row — labelled so it's clearly a picker */
.accent-custom-row {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 4px;
  background: #f5f5f5;
  border: 1px dashed #ccc;
  border-radius: 6px;
  padding: 5px 10px;
}

.accent-custom-label {
  font-size: 0.7rem;
  color: #666;
  flex: 1;
}

/* Custom swatch with label for bg/chip pickers */
.custom-swatch-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
}

.custom-swatch-label {
  font-size: 0.58rem;
  color: #999;
  white-space: nowrap;
}

.cp-swatch-btn {
  border-radius: 5px;
  border: 1.5px solid rgba(0,0,0,0.15);
  cursor: pointer;
  flex-shrink: 0;
  padding: 0;
  display: block;
  box-shadow: inset 0 0 0 1px rgba(255,255,255,0.2);
}
.cp-swatch-btn:hover { border-color: var(--primary); }

.cp-popup {
  background: #fff;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  box-shadow: 0 6px 24px rgba(0,0,0,0.18);
  padding: 10px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  width: 267px;
  transform: scale(0.78);
  transform-origin: top left;
}

