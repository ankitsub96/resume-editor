  top: calc(var(--toolbar-height) + 4px);
  background: var(--panel-bg);
  border: 1px solid var(--panel-border);
  border-radius: 8px;
  box-shadow: var(--panel-shadow);
  min-width: 260px;
  max-width: 320px;
  z-index: 200;
  overflow: hidden;
}

