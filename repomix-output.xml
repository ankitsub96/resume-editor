}
.files-action__text small {
  font-size: 11px;
  color: #888;
}
.files-action__badge {
  font-size: 11px;
  color: #2a9d5c;
  font-weight: 600;
  flex-shrink: 0;
}
.files-divider {
  height: 1px;
  background: #eee;
