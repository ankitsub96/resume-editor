}

function HBSPreview() {
  return (
    <div className="tpl-preview">
      {/* Centered header */}
      <div className="tpl-header-bar tpl-header-bar--centered">
        <div className="tpl-name-line tpl-name-line--centered" />
        <div className="tpl-subtitle-line tpl-subtitle-line--centered" />
