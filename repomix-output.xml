<file path="src/components/panels/ConfigPanel.css">
.config-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.45);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.config-panel {
  background: #fff;
  border-radius: 10px;
  box-shadow: 0 8px 40px rgba(0,0,0,0.3);
  width: 820px;
  max-width: 95vw;
  height: 80vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.config-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 18px;
  border-bottom: 1px solid #e8e8e8;
  background: #f8f8f8;
  flex-shrink: 0;
}

.config-title {
  font-size: 0.95rem;
  font-weight: 700;
  color: #222;
}

.config-header-actions {
  display: flex;
  align-items: center;
  gap: 8px;
}

.config-close {
  font-size: 1.2rem;
  color: #888;
  padding: 0 4px;
  background: none;
  border: none;
  cursor: pointer;
  line-height: 1;
}
.config-close:hover { color: #333; }

.cfg-btn {
  font-size: 0.75rem;
  padding: 4px 10px;
  border-radius: 4px;
  border: 1px solid #ddd;
  background: #fff;
  color: #444;
  cursor: pointer;
  transition: background 0.12s;
}
.cfg-btn:hover { background: #f0f0f0; }
.cfg-btn--primary { background: var(--primary); color: #fff; border-color: transparent; }
.cfg-btn--primary:hover { background: var(--primary-dark); }
.cfg-btn--primary:disabled { opacity: 0.4; cursor: not-allowed; }
.cfg-btn--danger { color: #c0392b; border-color: #e0b0b0; }
.cfg-btn--danger:hover { background: #fff0f0; }

.config-body {
  display: flex;
  flex: 1;
  overflow: hidden;
}

/* Left nav */
.config-nav {
  width: 180px;
  flex-shrink: 0;
  border-right: 1px solid #ebebeb;
  overflow-y: auto;
  padding: 8px 0;
  display: flex;
  flex-direction: column;
}

.config-nav-item {
  text-align: left;
  padding: 7px 16px;
  font-size: 0.78rem;
  color: #555;
  background: none;
  border: none;
  cursor: pointer;
  border-left: 3px solid transparent;
  transition: background 0.1s;
}
.config-nav-item:hover { background: #f5f5f5; color: #222; }
.config-nav-item.active { color: var(--primary); font-weight: 600; border-left-color: var(--primary); background: rgba(90,122,74,0.06); }

.config-nav-divider {
  flex: 1;
  min-height: 16px;
}

.config-paste-area {
  padding: 12px;
  border-top: 1px solid #ebebeb;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.config-paste-label {
  font-size: 0.7rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: #888;
}

.config-paste-input {
  font-family: monospace;
  font-size: 0.68rem;
  border: 1px solid #ddd;
  border-radius: 4px;
  padding: 6px;
  resize: vertical;
  color: #333;
  outline: none;
}
.config-paste-input:focus { border-color: var(--primary); }

.config-paste-error {
  font-size: 0.68rem;
  color: #c0392b;
}

/* Right fields */
.config-fields {
  flex: 1;
  overflow-y: auto;
  padding: 16px 20px;
}

.config-section-block {}

.config-section-heading {
  font-size: 0.8rem;
  font-weight: 700;
  color: var(--primary);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin-bottom: 14px;
  padding-bottom: 6px;
  border-bottom: 1.5px solid var(--primary);
}

.config-field-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.config-field {
  display: flex;
  align-items: center;
  gap: 10px;
}

.config-field--bool {
  gap: 8px;
}

.config-field-label {
  font-size: 0.74rem;
  color: #555;
  width: 200px;
  flex-shrink: 0;
  font-family: monospace;
}

.config-field-row {
  display: flex;
  align-items: center;
  gap: 6px;
  flex: 1;
}

.config-field-input {
  flex: 1;
  border: 1px solid #ddd;
  border-radius: 4px;
  padding: 4px 8px;
  font-size: 0.76rem;
  font-family: monospace;
  color: #222;
  outline: none;
}
.config-field-input:focus { border-color: var(--primary); }
.config-field-input--num { max-width: 80px; }

.config-field--slider { align-items: center; }

.config-slider-row {
  display: flex;
  align-items: center;
  gap: 10px;
  flex: 1;
}

.config-slider {
  flex: 1;
  accent-color: var(--primary);
  height: 4px;
  cursor: pointer;
}

.config-slider-val {
  font-size: 0.72rem;
  font-family: monospace;
  color: #555;
  min-width: 36px;
  text-align: right;
}

.config-color-swatch {
  width: 28px;
  height: 28px;
  border-radius: 4px;
  border: 1px solid #ddd;
  padding: 1px;
  cursor: pointer;
  flex-shrink: 0;
}

.config-field-group {
  border-left: 3px solid #ebebeb;
  padding-left: 10px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.config-field-group-label {
  font-size: 0.72rem;
  font-weight: 600;
  color: #888;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: 2px;
}
</file>

