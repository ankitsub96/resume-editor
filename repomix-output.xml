  cursor: not-allowed;
}

.toolbar-btn--primary {
  background: rgba(0,0,0,0.2);
  color: var(--chip-text, #fff);
  font-weight: 700;
  padding: 0 20px;
  border-radius: 5px;
  margin: 8px 0 8px 6px;
